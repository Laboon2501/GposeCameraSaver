<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <Version>1.0.1.0</Version>
    <AssemblyName>GposeCameraSaver</AssemblyName>
    <RepoUrl>https://github.com/Laboon2501/GposeCameraSaver</RepoUrl>
    <IconUrl>https://raw.githubusercontent.com/Laboon2501/GposeCameraSaver/main/icon.png</IconUrl>
    <PackageProjectUrl>https://github.com/Laboon2501/GposeCameraSaver</PackageProjectUrl>
    <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
    <IsPackable>false</IsPackable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <None Include="images\icon.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
